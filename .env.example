REACT_APP_KAKAO_API_KEY=your_kakao_js_api_key_here
REACT_APP_API_BASE_URL=http://localhost:8080/api


# ============================================================
# application.properties 설정 예시
# backend/src/main/resources/application.properties 파일을 생성하세요
# ============================================================

spring.datasource.url=jdbc:postgresql://localhost:5432/flatmap_db
spring.datasource.username=your_db_username
spring.datasource.password=your_db_password
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.properties.hibernate.format_sql=true

server.port=8080

# ============================================================
# Kakao API
# ============================================================
kakao.rest-api-key=your_kakao_rest_api_key_here

# ============================================================
# T Map API
# ============================================================
tmap.app-key=your_tmap_app_key_here

# ============================================================
# 기상청 (공공데이터포털)
# ============================================================
weather.api-key=your_weather_api_key_here

# ============================================================
# 공공데이터 API
# ============================================================
public-data.api-key=your_public_data_api_key_here

# ============================================================
# 경기데이터드림 API
# ============================================================
gyeonggi.security-light.api-key=your_gyeonggi_security_light_api_key_here
gyeonggi.accident-icy.api-key=your_gyeonggi_accident_icy_api_key_here
gyeonggi.accident-normal.api-key=your_gyeonggi_accident_normal_api_key_here
gyeonggi.uphill-lane.api-key=your_gyeonggi_uphill_lane_api_key_here
gyeonggi.senior-welfare.api-key=your_gyeonggi_senior_welfare_api_key_here
gyeonggi.senior-center.api-key=your_gyeonggi_senior_center_api_key_here

# ============================================================
# 재난안전데이터공유플랫폼 API
# ============================================================
disaster.steep-slope.api-key=your_disaster_steep_slope_api_key_here
disaster.traffic-downhill.api-key=your_disaster_traffic_downhill_api_key_here
disaster.steep-slope-final.api-key=your_disaster_steep_slope_final_api_key_here

# ============================================================
# 성남시 지역 코드
# ============================================================
region.seongnam=41130
region.sujeong=41131
region.jungwon=41133
region.bundang=41135

# ============================================================
# Logging
# ============================================================
logging.file.name=logs/app.log
logging.level.root=INFO
logging.level.com.flatmap.navigation=DEBUG
logging.pattern.file=%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n
logging.logback.rollingpolicy.max-file-size=10MB
logging.logback.rollingpolicy.max-history=7
